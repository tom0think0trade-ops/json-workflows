      "parameters": {
        "jsCode": "// Node: 6 - Parse Products JSON\n// Mode: Run Once for All Items\n\nconst crypto = require('crypto'); // available in n8n Cloud :contentReference[oaicite:8]{index=8}\n\nconst resp = $json?.body ?? $json;\n\n// Extract assistant text from OpenAI Responses API (raw HTTP response uses `output`) :contentReference[oaicite:9]{index=9}\nfunction extractTextFromResponsesAPI(r) {\n  if (!r) return null;\n  if (typeof r === 'string') return r;\n\n  const out = r.output;\n  if (!Array.isArray(out)) return null;\n\n  for (const item of out) {\n    const content = item?.content;\n    if (!Array.isArray(content)) continue;\n\n    for (const c of content) {\n      if (typeof c?.text === 'string' && c.text.trim()) return c.text;\n    }\n  }\n  return null;\n}\n\nfunction normalizeUrl(u) {\n  if (!u || typeof u !== 'string') return '';\n  let s = u.trim();\n  s = s.split('#')[0];\n  s = s.split('?')[0];\n  try {\n    const url = new URL(s);\n    url.hash = '';\n    url.search = '';\n    url.hostname = url.hostname.replace(/^www\\./, '');\n    return url.toString().replace(/\\/$/, '');\n  } catch {\n    return s.replace(/\\/$/, '');\n  }\n}\n\nfunction sha256(text) {\n  return crypto.createHash('sha256').update(text).digest('hex');\n}\n\nconst text = extractTextFromResponsesAPI(resp);\nif (!text) {\n  throw new Error(\"OpenAI response had no output text. Check Node 4 output shape (should include `output`).\");\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  // salvage attempt if extra text accidentally wrapped JSON\n  const a = text.indexOf('{');\n  const b = text.lastIndexOf('}');\n  if (a >= 0 && b > a) parsed = JSON.parse(text.slice(a, b + 1));\n  else throw new Error(\"Model output wasn't valid JSON. Raw text:\\n\" + text);\n}\n\nif (!Array.isArray(parsed.products)) {\n  throw new Error(\"Parsed JSON missing `products` array.\");\n}\n\nreturn parsed.products.map((p) => {\n  const supplierUrl = String(p.supplier_url ?? '').trim();\n  const supplierUrlNorm = normalizeUrl(supplierUrl);\n\n  // fingerprint: SHA256(normalized URL). You can add title too if you want:\n  // const fp = sha256(`${supplierUrlNorm}|${String(p.title ?? '').trim().toLowerCase()}`);\n  const fp = sha256(supplierUrlNorm);\n\n  return {\n    json: {\n      status: \"review\",\n      title: String(p.title ?? \"\").trim(),\n      supplier: String(p.supplier ?? \"\").trim(),\n      supplier_url: supplierUrl,\n      supplier_url_normalized: supplierUrlNorm,\n      fingerprint: fp,\n      cost: Number(p.cost ?? 0),\n      suggested_price: Number(p.suggested_price ?? 0),\n      margin_multiplier: Number(p.margin_multiplier ?? 0),\n      why_it_wins: String(p.why_it_wins ?? \"\"),\n      risks: String(p.risks ?? \"\"),\n      seo_keywords: String(p.seo_keywords ?? \"\"),\n      image_urls: Array.isArray(p.image_urls) ? p.image_urls.join(\"\\n\") : \"\"\n    }\n  };\n});\n"
      },
