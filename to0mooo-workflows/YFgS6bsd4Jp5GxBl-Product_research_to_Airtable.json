        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-5-mini\",\n  \"input\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a product research engine for a dropshipping store. Return ONLY valid JSON.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Find 5 non-restricted, non-branded, trending products suitable for {{ $json.niche_focus }} (or general if auto). Market: {{ $json.country_market }}. Max cost: {{ $json.max_product_cost }}. Minimum margin multiplier: {{ $json.min_margin_multiplier }}. Include supplier_url and 3 image_urls each.\"\n    }\n  ],\n  \"text\": {\n    \"format\": {\n      \"type\": \"json_schema\",\n      \"name\": \"products_schema\",\n      \"strict\": true,\n      \"schema\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"products\": {\n            \"type\": \"array\",\n            \"items\": {\n              \"type\": \"object\",\n              \"additionalProperties\": false,\n              \"properties\": {\n                \"title\": {\"type\": \"string\"},\n                \"supplier\": {\"type\": \"string\"},\n                \"supplier_url\": {\"type\": \"string\"},\n                \"cost\": {\"type\": \"number\"},\n                \"suggested_price\": {\"type\": \"number\"},\n                \"margin_multiplier\": {\"type\": \"number\"},\n                \"why_it_wins\": {\"type\": \"string\"},\n                \"risks\": {\"type\": \"string\"},\n                \"seo_keywords\": {\"type\": \"string\"},\n                \"image_urls\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}}\n              },\n              \"required\": [\"title\",\"supplier\",\"supplier_url\",\"cost\",\"suggested_price\",\"margin_multiplier\",\"why_it_wins\",\"risks\",\"seo_keywords\",\"image_urls\"]\n            }\n          }\n        },\n        \"required\": [\"products\"],\n        \"additionalProperties\": false\n      }\n    }\n  }\n}\n",
        "options": {}
